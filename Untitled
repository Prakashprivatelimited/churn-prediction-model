'customer_id':    range(1, n + 1),\n","    'age':            np.random.randint(18, 65, n),\n","    'gender':         np.random.choice(['Male', 'Female'], n),\n","    'city':           np.random.choice(['Chennai', 'Mumbai', 'Delhi', 'Bangalore', 'Hyderabad'], n),\n","    'total_orders':   np.random.randint(1, 50, n),\n","    'total_spent':    np.random.uniform(500, 50000, n).round(2),\n","    'avg_order_value':np.random.uniform(200, 5000, n).round(2),\n","    'last_purchase_days': np.random.randint(1, 365, n),\n","    'category':       np.random.choice(['Electronics', 'Fashion', 'Food', 'Books', 'Beauty'], n),\n","    'rating':         np.random.randint(1, 6, n),\n","})\n","\n","print(\"✅ STEP 1: Data Loaded\")\n","print(f\"   Total Customers: {len(data)}\")\n","print(f\"   Total Revenue: ₹{data['total_spent'].sum():,.0f}\\n\")\n","\n","\n","# ─────────────────────────────────────────\n","# STEP 2: KEY BUSINESS INSIGHTS\n","# ─────────────────────────────────────────\n","\n","print(\"✅ STEP 2: Key Business Insights\")\n","\n","# Top Cities by Revenue\n","top_cities = data.groupby('city')['total_spent'].sum().sort_values(ascending=False)\n","print(\"\\n📍 Top Cities by Revenue:\")\n","print(top_cities.to_string())\n","\n","# Top Categories\n","top_categories = data.groupby('category')['total_orders'].sum().sort_values(ascending=False)\n","print(\"\\n🛒 Top Categories by Orders:\")\n","print(top_categories.to_string())\n","\n","# Customer Segments by Spending\n","data['segment'] = pd.cut(\n","    data['total_spent'],\n","    bins=[0, 5000, 20000, 50000],\n","    labels=['Budget', 'Mid-range', 'Premium']\n",")\n","segments = data['segment'].value_counts()\n","print(\"\\n👥 Customer Segments:\")\n","print(segments.to_string())\n","\n","# Average Rating\n","print(f\"\\n⭐ Average Customer Rating: {data['rating'].mean():.1f} / 5\")\n","\n","\n","# ─────────────────────────────────────────\n","# STEP 3: VISUALIZATIONS (CHARTS)\n","# ─────────────────────────────────────────\n","\n","fig = plt.figure(figsize=(16, 12))\n","fig.suptitle('E-Commerce Customer Analysis Dashboard', fontsize=18, fontweight='bold', y=0.98)\n","gs = gridspec.GridSpec(2, 3, figure=fig, hspace=0.4, wspace=0.35)\n","\n","# Chart 1 — Revenue by City\n","ax1 = fig.add_subplot(gs[0, 0])\n","top_cities.plot(kind='bar', ax=ax1, color='steelblue', edgecolor='white')\n","ax1.set_title('Revenue by City', fontweight='bold')\n","ax1.set_xlabel('City')\n","ax1.set_ylabel('Total Revenue (₹)')\n","ax1.tick_params(axis='x', rotation=30)\n","\n","# Chart 2 — Orders by Category\n","ax2 = fig.add_subplot(gs[0, 1])\n","top_categories.plot(kind='bar', ax=ax2, color='coral', edgecolor='white')\n","ax2.set_title('Orders by Category', fontweight='bold')\n","ax2.set_xlabel('Category')\n","ax2.set_ylabel('Total Orders')\n","ax2.tick_params(axis='x', rotation=30)\n","\n","# Chart 3 — Customer Segments Pie\n","ax3 = fig.add_subplot(gs[0, 2])\n","segments.plot(kind='pie', ax=ax3, autopct='%1.1f%%',\n","              colors=['#66b3ff','#ffcc99','#99ff99'],\n","              startangle=90)\n","ax3.set_title('Customer Segments', fontweight='bold')\n","ax3.set_ylabel('')\n","\n","# Chart 4 — Age Distribution\n","ax4 = fig.add_subplot(gs[1, 0])\n","ax4.hist(data['age'], bins=20, color='mediumpurple', edgecolor='white')\n","ax4.set_title('Customer Age Distribution', fontweight='bold')\n","ax4.set_xlabel('Age')\n","ax4.set_ylabel('Count')\n","\n","# Chart 5 — Gender Split\n","ax5 = fig.add_subplot(gs[1, 1])\n","gender_counts = data['gender'].value_counts()\n","ax5.pie(gender_counts, labels=gender_counts.index, autopct='%1.1f%%',\n","        colors=['#ff9999','#66b3ff'], startangle=90)\n","ax5.set_title('Gender Distribution', fontweight='bold')\n","\n","# Chart 6 — Rating Distribution\n","ax6 = fig.add_subplot(gs[1, 2])\n","rating_counts = data['rating'].value_counts().sort_index()\n","rating_counts.plot(kind='bar', ax=ax6, color='gold', edgecolor='white')\n","ax6.set_title('Customer Ratings', fontweight='bold')\n","ax6.set_xlabel('Rating (1-5)')\n","ax6.set_ylabel('Count')\n","ax6.tick_params(axis='x', rotation=0)\n","\n","plt.savefig('/mnt/user-data/outputs/ecommerce_dashboard.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","print(\"\\n✅ STEP 3: Dashboard Saved as 'ecommerce_dashboard.png'\")\n","\n","\n","# ─────────────────────────────────────────\n","# STEP 4: FINAL REPORT FOR CLIENT\n","# ─────────────────────────────────────────\n","\n","print()\n","print(\"=\" * 55)\n","print(\"📊 FINAL REPORT FOR E-COMMERCE CLIENT\")\n","print(\"=\" * 55)\n","print(f\"  Total Customers Analyzed : {len(data)}\")\n","print(f\"  Total Revenue            : ₹{data['total_spent'].sum():,.0f}\")\n","print(f\"  Average Order Value      : ₹{data['avg_order_value'].mean():,.0f}\")\n","print(f\"  Top City                 : {top_cities.idxmax()}\")\n","print(f\"  Top Category             : {top_categories.idxmax()}\")\n","print(f\"  Premium Customers        : {(data['segment']=='Premium').sum()}\")\n","print(f\"  Average Rating           : {data['rating'].mean():.1f} / 5\")\n","print(\"=\" * 55)\n","print(\"\\n💡 RECOMMENDATIONS:\")\n","print(\"  1. Focus marketing on\", top_cities.idxmax(), \"— highest revenue city\")\n","print(\"  2. Stock more\", top_categories.idxmax(), \"— most ordered category\")\n","print(\"  3. Reward Premium customers with loyalty program\")\n","print(\"  4. Improve rating — target customers who gave 1-2 stars\")"]}]}